{
  "version": 1,
  "functions": {
    "/_middleware": {
      "runtime": "nodejs",
      "matchers": [
        {
          "regexp": "^(?:\\/(_next\\/data\\/[^/]{1,}))?(?:\\/((?!api|_next|images|favicon.ico|favicon.svg|robots.txt|sitemap.xml).*))(\\.json)?[\\/#\\?]?$",
          "originalSource": "/((?!api|_next|images|favicon.ico|favicon.svg|robots.txt|sitemap.xml).*)"
        }
      ]
    }
  }
}