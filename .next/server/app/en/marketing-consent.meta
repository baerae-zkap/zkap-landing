{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/marketing-consent/layout,_N_T_/[locale]/marketing-consent/page,_N_T_/en/marketing-consent"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/marketing-consent/__PAGE__",
    "/$d$locale/marketing-consent",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}