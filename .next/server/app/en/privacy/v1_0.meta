{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/privacy/layout,_N_T_/[locale]/privacy/v1_0/layout,_N_T_/[locale]/privacy/v1_0/page,_N_T_/en/privacy/v1_0"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/privacy/v1_0/__PAGE__",
    "/$d$locale/privacy/v1_0",
    "/$d$locale/privacy",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}